generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  telegramId   String   @unique
  name         String?
  transactions Transaction[]
  budgets      Budget[]
  goals        Goal[]
}

model Transaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  amount    Float
  category  String
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Budget {
  id          Int      @id @default(autoincrement())
  userId      Int
  category    String
  limitAmount Float
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, category])
}

model Goal {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  target    Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, name])
}